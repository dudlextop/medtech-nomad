{
  "name": "nomad-radar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "data:import": "CODEX_PYTHON=${CODEX_PYTHON:-python3}; \"$CODEX_PYTHON\" scripts/import_runner.py",
    "data:normalize": "CODEX_PYTHON=${CODEX_PYTHON:-python3}; \"$CODEX_PYTHON\" scripts/normalization/normalize_services.py",
    "data:analytics": "CODEX_PYTHON=${CODEX_PYTHON:-python3}; \"$CODEX_PYTHON\" scripts/analytics/build_analytics.py",
    "web:discover": "CODEX_PYTHON=${CODEX_PYTHON:-python3}; \"$CODEX_PYTHON\" scripts/discover_web_sources.py",
    "web:data": "CODEX_PYTHON=${CODEX_PYTHON:-python3}; \"$CODEX_PYTHON\" scripts/importers/parse_web_sources.py",
    "data:public-ui": "CODEX_PYTHON=${CODEX_PYTHON:-python3}; \"$CODEX_PYTHON\" scripts/normalization/build_public_ui_dataset.py",
    "data:build": "npm run data:import && npm run data:normalize && npm run data:analytics && npm run data:public-ui"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "lucide-react": "0.468.0",
    "next": "^16.2.9",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "8.4.39",
    "tailwindcss": "3.4.4",
    "typescript": "5.5.3"
  }
}
